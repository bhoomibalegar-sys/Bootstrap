<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Student Attendance System</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<div class="container mt-5">
  <h2 class="text-center mb-4">Student Attendance System</h2>

  <!-- Add Student Form -->
  <div class="card p-3 mb-4">
    <div class="row">
      <div class="col-md-5">
        <input type="text" id="studentName" class="form-control" placeholder="Enter Student Name">
      </div>
      <div class="col-md-3">
        <input type="text" id="studentRoll" class="form-control" placeholder="Enter Roll No">
      </div>
      <div class="col-md-2">
        <button class="btn btn-success w-100" onclick="addStudent()">Add</button>
      </div>
    </div>
  </div>

  <!-- Attendance Table -->
  <div class="table-responsive">
    <table class="table table-bordered table-striped text-center">
      <thead class="table-dark">
        <tr>
          <th>Roll No</th>
          <th>Name</th>
          <th>Attendance</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody id="studentTable">
        <!-- Dynamic rows -->
      </tbody>
    </table>
  </div>
</div>

<script>
let students = [];

function addStudent() {
  let name = document.getElementById("studentName").value;
  let roll = document.getElementById("studentRoll").value;

  if (name === "" || roll === "") {
    alert("Please fill all fields");
    return;
  }

  let student = {
    name: name,
    roll: roll,
    attendance: "Absent"
  };

  students.push(student);
  displayStudents();

  document.getElementById("studentName").value = "";
  document.getElementById("studentRoll").value = "";
}

function deleteStudent(index) {
  students.splice(index, 1);
  displayStudents();
}

function toggleAttendance(index) {
  students[index].attendance =
    students[index].attendance === "Present" ? "Absent" : "Present";
  displayStudents();
}

function displayStudents() {
  let table = document.getElementById("studentTable");
  table.innerHTML = "";

  students.forEach((student, index) => {
    let row = `
      <tr>
        <td>${student.roll}</td>
        <td>${student.name}</td>
        <td>
          <button class="btn btn-${student.attendance === "Present" ? "success" : "secondary"}"
            onclick="toggleAttendance(${index})">
            ${student.attendance}
          </button>
        </td>
        <td>
          <button class="btn btn-danger" onclick="deleteStudent(${index})">Delete</button>
        </td>
      </tr>
    `;
    table.innerHTML += row;
  });
}
</script>

</body>
</html>
